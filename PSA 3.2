  {"47B2BCAAC1690", "Alexandre"},
  {"413BF22161E95", "Andre"}
};

int totalUtilizadores = sizeof(utilizadores) / sizeof(utilizadores[0]);

// ===== HORÁRIO =====
int horaLimite   = 12;
int minutoLimite = 25;

// ===== JUSTIFICATIVAS DE ATRASO =====
String justificativas[] = {
  "",                    // 0 não usado
  "Autocarro atrasado",  // 1
  "Fila no bar",         // 2
  "Sai tarde de casa",   // 3
  "Transito",            // 4
  "",                    // 5 não usado
  "",                    // 6 não usado
  "",                    // 7 não usado
  "",                    // 8 não usado
