// ===== BUZZER =====
#define BUZZER_PIN 2

// ===== MICROSD SPI SEPARADO =====
#define SD_CS   47
#define SD_SCK  21
#define SD_MOSI 20
#define SD_MISO 19
SPIClass spiSD(HSPI);

// ===== WIFI =====
