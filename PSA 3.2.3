#include <WiFi.h>
#include <SPI.h>
#include <MFRC522.h>
#include <time.h>
#include <Keypad.h>

// ===== RFID =====
#define SS_PIN 10
#define RST_PIN 9
MFRC522 rfid(SS_PIN, RST_PIN);

// ===== BUZZER =====
#define BUZZER_PIN 2

// ===== WIFI =====
const char* ssid = "Jozze111";
const char* password = "Jozze111";

// ===== NTP =====
const char* ntpServer = "pool.ntp.org";
const long gmtOffset_sec = 0;
const int daylightOffset_sec = 3600;

// ===== KEYPAD =====
const byte ROWS = 4;
const byte COLS = 4;

char keys[ROWS][COLS] = {
  {'1','2','3','A'},
  {'4','5','6','B'},
  {'7','8','9','C'},
  {'*','0','#','D'}
};

byte rowPins[ROWS] = {42, 41, 40, 39};
byte colPins[COLS] = {38, 37, 36, 35};

Keypad keypad = Keypad(makeKeymap(keys), rowPins, colPins, ROWS, COLS);

// ===== UTILIZADORES =====
struct Utilizador {
  String uid;
  String nome;
};

Utilizador utilizadores[] = {
  {"A7272049",      "Joao"},
  {"F11FB7C1",      "Mariana"},
  {"47B2BCAAC1690", "Alexandre"},
  {"413BF22161E95", "Andre"}
};

int totalUtilizadores = sizeof(utilizadores) / sizeof(utilizadores[0]);

// ===== HORÁRIO =====
int horaLimite   = 00;
int minutoLimite = 25;

// ===== JUSTIFICATIVAS =====
String justificativas[] = {
  "",
  "Autocarro atrasado",
  "Fila no bar",
  "Sai tarde de casa",
  "Transito",
  "", "", "", "", ""
};

// ===== HISTÓRICO =====
struct Registo {
  String nome;
  String hora;
  String estado;
  int humor;
  String motivo;
};

Registo historico[20];
int totalRegistos = 0;

// ===== SERVER =====
WiFiServer server(80);

// ===== BUZZER =====
void bip(int vezes, int duracao = 100) {
  for (int i = 0; i < vezes; i++) {
    digitalWrite(BUZZER_PIN, HIGH);
    delay(duracao);
    digitalWrite(BUZZER_PIN, LOW);
    if (i < vezes - 1) delay(100);
  }
}

// ===== HORA =====
String getHora() {
  struct tm timeinfo;
  if (!getLocalTime(&timeinfo)) return "Erro";
  char hora[10];
  strftime(hora, sizeof(hora), "%H:%M", &timeinfo);
  return String(hora);
}

// ===== HUMOR =====
int charParaHumor(char c) {
  if (c == 'A') return 2;
  if (c == 'B') return 1;
  if (c == 'C') return 0;
  return 1;
}

String getNomeHumor(int humor) {
  if (humor == 2) return "Bom";
  if (humor == 1) return "Neutro";
  return "Mau";
}

String getEmojiHumor(int humor) {
  if (humor == 2) return "&#128512;";
  if (humor == 1) return "&#128528;";
  return "&#128577;";
}

String getCorHumor(int humor) {
  if (humor == 2) return "#00ff88";
  if (humor == 1) return "#ffaa00";
  return "#ff4c4c";
}

// ===== GERAR CONTEÚDO =====
String gerarConteudo() {
  String html = "";

  int totalOK     = 0;
  int totalAtraso = 0;
  int totalNegado = 0;
  int somaHumor   = 0;
  int countHumor  = 0;

  for (int i = 0; i < 20; i++) {
    if (historico[i].nome != "") {
      if      (historico[i].estado == "OK")       totalOK++;
      else if (historico[i].estado == "ATRASADO") totalAtraso++;
      else                                         totalNegado++;
      somaHumor += historico[i].humor;
      countHumor++;
    }
  }

  // ===== RESUMO =====
  html += "<div class='box'><h2>Resumo</h2>";
  html += "<p class='ok'>&#9989; Presentes: " + String(totalOK) + "</p>";
  html += "<p class='atraso'>&#9200; Atrasados: " + String(totalAtraso) + "</p>";
  html += "<p class='negado'>&#10060; Negados: " + String(totalNegado) + "</p>";
  if (countHumor > 0) {
    float media = (float)somaHumor / countHumor;
    String humorGeral = media >= 1.5 ? "Bom &#128512;" : media >= 0.5 ? "Neutro &#128528;" : "Mau &#128577;";
    html += "<p style='color:#00ccff;'>Humor medio da turma: " + humorGeral + "</p>";
  }
  html += "</div>";

  // ===== ÚLTIMO ACESSO =====
  if (totalRegistos > 0) {
    Registo u = historico[(totalRegistos - 1 + 20) % 20];
    String cor = getCorHumor(u.humor);
    html += "<div class='box'><h2>Ultimo acesso</h2>";
    if      (u.estado == "ATRASADO") html += "<p class='atraso'>&#9200; " + u.nome + " - " + u.hora + " - ATRASADO</p>";
    else if (u.estado == "OK")       html += "<p class='ok'>&#9989; "     + u.nome + " - " + u.hora + " - OK</p>";
    else                             html += "<p class='negado'>&#10060; " + u.nome + " - " + u.hora + " - NEGADO</p>";
    if (u.motivo != "")
      html += "<p class='atraso'>Motivo: " + u.motivo + "</p>";
    html += "<p style='color:" + cor + ";font-size:1.5em;'>" + getEmojiHumor(u.humor) + " " + getNomeHumor(u.humor) + "</p>";
    html += "</div>";
  }

  // ===== TABELA ÚNICA COM TUDO =====
  html += "<div class='box'><h2>Registos</h2><table>";
  html += "<tr><th>Nome</th><th>Hora</th><th>Estado</th><th>Motivo Atraso</th><th>Humor</th></tr>";

  for (int i = 0; i < 20; i++) {
    if (historico[i].nome != "") {
      String corHumor  = getCorHumor(historico[i].humor);
      String classeEstado = "";
      String iconeEstado  = "";

      if      (historico[i].estado == "ATRASADO") { classeEstado = "atraso"; iconeEstado = "&#9200; "; }
      else if (historico[i].estado == "OK")       { classeEstado = "ok";     iconeEstado = "&#9989; "; }
      else                                         { classeEstado = "negado"; iconeEstado = "&#10060; "; }

      html += "<tr>";
      html += "<td><b>" + historico[i].nome + "</b></td>";
      html += "<td>" + historico[i].hora + "</td>";
      html += "<td class='" + classeEstado + "'>" + iconeEstado + historico[i].estado + "</td>";
      html += "<td>" + (historico[i].motivo != "" ? historico[i].motivo : "-") + "</td>";
      html += "<td style='color:" + corHumor + ";font-size:1.2em;'>" + getEmojiHumor(historico[i].humor) + " " + getNomeHumor(historico[i].humor) + "</td>";
      html += "</tr>";
    }
  }

  html += "</table></div>";
  return html;
}

// ===== SERVIR PÁGINA PRINCIPAL =====
void servirPaginaPrincipal(WiFiClient client) {
  client.println("HTTP/1.1 200 OK");
  client.println("Content-Type: text/html; charset=UTF-8");
  client.println("Cache-Control: no-cache");
  client.println("Connection: close");
  client.println();
  client.println("<!DOCTYPE html><html><head><meta charset='UTF-8'>");
  client.println("<title>Presenca em Sala de Aula</title>");
  client.println("<style>");
  client.println("body{font-family:Arial;background:#1e1e2f;color:white;text-align:center;margin:0;padding:20px;}");
  client.println("h1{margin-bottom:20px;}");
  client.println("h2{color:#aaaaff;}");
  client.println(".box{background:#2c2c3e;margin:20px auto;padding:20px;border-radius:10px;max-width:900px;}");
  client.println(".ok{color:#00ff88;}");
  client.println(".atraso{color:#ff4c4c;}");
  client.println(".negado{color:#ffaa00;}");
  client.println("table{width:100%;border-collapse:collapse;}");
  client.println("th{padding:10px;border-bottom:2px solid #666;color:#aaaaff;text-align:left;}");
  client.println("td{padding:10px;border-bottom:1px solid #444;text-align:left;}");
  client.println("tr:hover{background:#3a3a4e;}");
  client.println("</style>");
  client.println("<script>");
  client.println("window.onload=function(){setInterval(function(){fetch('/dados').then(function(r){return r.text();}).then(function(d){if(d.indexOf('<h1>')===-1){document.getElementById('conteudo').innerHTML=d;}});},2000);};");
  client.println("</script>");
  client.println("</head><body>");
  client.println("<h1>&#127979; PRESENCA EM SALA DE AULA</h1>");
  client.println("<div id='conteudo'>");
  client.println(gerarConteudo());
  client.println("</div>");
  client.println("</body></html>");
  client.stop();
}

// ===== SETUP =====
void setup() {
  Serial.begin(115200);

  pinMode(BUZZER_PIN, OUTPUT);
  digitalWrite(BUZZER_PIN, LOW);

  SPI.begin(12, 13, 11, 10);
  rfid.PCD_Init();

  WiFi.begin(ssid, password);
  Serial.print("Ligando WiFi");
  while (WiFi.status() != WL_CONNECTED) {
    delay(500);
    Serial.print(".");
  }

  Serial.println("\nWiFi ligado!");
  Serial.println(WiFi.localIP());

  configTime(gmtOffset_sec, daylightOffset_sec, ntpServer);

  server.begin();
  bip(2, 150);
  Serial.println("Passe o cartao...");
}

// ===== LOOP =====
void loop() {

  if (rfid.PICC_IsNewCardPresent() && rfid.PICC_ReadCardSerial()) {

    bip(1, 80);

    String uid = "";
    for (byte i = 0; i < rfid.uid.size; i++) {
      uid += String(rfid.uid.uidByte[i], HEX);
    }
    uid.toUpperCase();
    uid.trim();
    Serial.println("UID: " + uid);

    String horaAtual = getHora();
    String nome      = "DESCONHECIDO";
    String estado    = "NEGADO";

    int hora   = horaAtual.substring(0, 2).toInt();
    int minuto = horaAtual.substring(3, 5).toInt();

    for (int i = 0; i < totalUtilizadores; i++) {
      if (uid == utilizadores[i].uid) {
        nome = utilizadores[i].nome;
        estado = (hora < horaLimite || (hora == horaLimite && minuto <= minutoLimite)) ? "OK" : "ATRASADO";
      }
    }

    if      (estado == "OK")       bip(1, 300);
    else if (estado == "ATRASADO") bip(2, 200);
    else                           bip(3, 80);

    // ===== HUMOR =====
    Serial.println("Humor: A=Bom  B=Neutro  C=Mau  (10 seg)");
    int humor = 1;
    unsigned long tempoInicio = millis();
    bool introduzido = false;

    while (millis() - tempoInicio < 10000) {
      char tecla = keypad.getKey();
      if (tecla == 'A' || tecla == 'B' || tecla == 'C') {
        humor = charParaHumor(tecla);
        introduzido = true;
        Serial.println("Humor: " + getNomeHumor(humor));
        break;
      }
      WiFiClient client = server.available();
      if (client) {
        String request = "";
        while (client.connected() && client.available()) {
          char c = client.read();
          request += c;
          if (request.endsWith("\r\n\r\n")) break;
        }
        if (request.startsWith("GET /dados")) {
          client.println("HTTP/1.1 200 OK");
          client.println("Content-Type: text/html; charset=UTF-8");
          client.println("Cache-Control: no-cache");
          client.println("Connection: close");
          client.println();
          client.println(gerarConteudo());
          client.stop();
        } else {
          servirPaginaPrincipal(client);
        }
      }
      yield();
      delay(50);
    }
    if (!introduzido) Serial.println("Tempo esgotado! Humor padrao: Neutro");

    // ===== MOTIVO ATRASO =====
    String motivo = "";
    if (estado == "ATRASADO") {
      Serial.println("Motivo: 1=Autocarro  2=Fila bar  3=Sai tarde  4=Transito  (10 seg)");
      tempoInicio = millis();
      introduzido = false;
      while (millis() - tempoInicio < 10000) {
        char tecla = keypad.getKey();
        if (tecla >= '1' && tecla <= '4') {
          motivo = justificativas[tecla - '0'];
          introduzido = true;
          Serial.println("Motivo: " + motivo);
          break;
        }
        WiFiClient client = server.available();
        if (client) {
          String request = "";
          while (client.connected() && client.available()) {
            char c = client.read();
            request += c;
            if (request.endsWith("\r\n\r\n")) break;
          }
          if (request.startsWith("GET /dados")) {
            client.println("HTTP/1.1 200 OK");
            client.println("Content-Type: text/html; charset=UTF-8");
            client.println("Cache-Control: no-cache");
            client.println("Connection: close");
            client.println();
            client.println(gerarConteudo());
            client.stop();
          } else {
            servirPaginaPrincipal(client);
          }
        }
        yield();
        delay(50);
      }
      if (!introduzido) {
        motivo = "Nao indicado";
        Serial.println("Motivo nao indicado.");
      }
    }

    Serial.println(nome + " - " + horaAtual + " - " + estado + " | Humor: " + getNomeHumor(humor) + " | Motivo: " + motivo);

    historico[totalRegistos].nome   = nome;
    historico[totalRegistos].hora   = horaAtual;
    historico[totalRegistos].estado = estado;
    historico[totalRegistos].humor  = humor;
    historico[totalRegistos].motivo = motivo;
    totalRegistos++;
    if (totalRegistos >= 20) totalRegistos = 0;

    rfid.PICC_HaltA();
    rfid.PCD_StopCrypto1();
    delay(500);
  }

  // ===== WEB =====
  WiFiClient client = server.available();
  if (client) {
    String request = "";
    while (client.connected() && client.available()) {
      char c = client.read();
      request += c;
      if (request.endsWith("\r\n\r\n")) break;
    }
    if (request.startsWith("GET /dados")) {
      client.println("HTTP/1.1 200 OK");
      client.println("Content-Type: text/html; charset=UTF-8");
      client.println("Cache-Control: no-cache");
      client.println("Connection: close");
      client.println();
      client.println(gerarConteudo());
      client.stop();
      return;
    }
    servirPaginaPrincipal(client);
  }
}
